[-4.49630451 22.96999168]
[-9.39950275 7.32100821]
[1.89896715 -4.56497574]
[17.77620888 -0.46067846]
[21.89907646 15.41175079]
[32.77096939 25.74625397]
[43.64286041 36.08075714]
[54.51475143 46.41526031]
[65.38664246 56.74976730]
[76.25853729 67.08426666]
[89.74703217 60.73195648]
[104.61926270 59.67922592]
[118.86808014 64.06814575]
[130.57048035 73.30639648]
[138.14710999 86.14719391]
[140.57545471 100.85755157]
[137.52775574 115.45217133]
[129.41535950 127.96138763]
[117.33309174 136.69696045]
[102.91156006 140.47993469]
[88.09709167 138.79978943]
] def
/arcs [
[]
[]
[]
[]
[]
[]
[]
